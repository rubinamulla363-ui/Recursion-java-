public class Recursion {

    static int sumEvenDigits(int n) {

        if (n == 0) {
            return 0;
        }

        int digit = n % 10;

        if (digit % 2 == 0) {
            return digit + sumEvenDigits(n / 10);
        } else {
            return sumEvenDigits(n / 10);
        }
    }

    public static void main(String[] args) {

        int num = 123456;

        System.out.println("Sum of even digits = " + sumEvenDigits(num));
    }
}